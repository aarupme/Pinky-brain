#!/usr/bin/env bash
set -euo pipefail
msg="${1:?usage: pinky-send-chatgpt MESSAGE}"
osascript - "$msg" <<'APPLESCRIPT'
on run argv
set msgText to item 1 of argv
tell application "ChatGPT" to activate
delay 0.3
tell application "System Events"
tell process "ChatGPT"
set frontmost to true
delay 0.2
set targetArea to missing value
try
set uiList to entire contents of window 1
repeat with itemRef in uiList
set roleText to ""
try
set roleText to value of attribute "AXRole" of itemRef as text
end try
if roleText is "AXTextArea" then set targetArea to itemRef
end repeat
end try
if targetArea is missing value then error "No ChatGPT text area found"
set focused of targetArea to true
delay 0.1
set value of targetArea to msgText
delay 0.1
key code 36
end tell
end tell
end run
APPLESCRIPT
