#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/../.."
mkdir -p v2/.run
on_stop() {
id="$(cat v2/.run/expected-id 2>/dev/null || printf 0001)"
v2/bin/pinky-send-chatgpt "Pinky stopped expected=PINKY_BASH_${id}" || true
printf "\nPINKY_BRAIN_STOPPED expected=PINKY_BASH_%s\n" "$id"
exit 0
}
trap on_stop INT TERM
printf "\nPINKY_BRAIN_CONSOLE_LISTENING\n"
while true; do
id="$(cat v2/.run/expected-id 2>/dev/null || printf 0001)"
raw="$(v2/bin/pinky-read-chatgpt || true)"
if printf "%s\n" "$raw" | v2/bin/pinky-parse-next "$id" > v2/.run/current-command.sh; then
if [ ! -s v2/.run/current-command.sh ]; then sleep 1; continue; fi
v2/bin/pinky-normalize-command v2/.run/current-command.sh
chmod +x v2/.run/current-command.sh
printf "\nPINKY_RUNNING_%s\n" "$id"
printf "\n--- command ---\n"
cat v2/.run/current-command.sh
printf "\n--- output ---\n"
set +e
bash v2/.run/current-command.sh 2>&1 | tee v2/.run/terminal-output.txt
rc="${PIPESTATUS[0]}"
set -e
printf "\nPINKY_DONE_%s:%s\n" "$id" "$rc"
next="$(printf "%04d" "$((10#$id + 1))")"
if [ -f v2/.run/stop-request ]; then
rm -f v2/.run/stop-request
printf "%s\n" "$next" > v2/.run/expected-id
v2/bin/pinky-send-chatgpt "Pinky stopped expected=PINKY_BASH_${next}" || true
printf "\nPINKY_BRAIN_STOPPED expected=PINKY_BASH_%s\n" "$next"
exit 0
fi
printf "%s\n" "$next" > v2/.run/expected-id
if [ "$rc" -eq 0 ]; then
v2/bin/pinky-send-chatgpt "Narf! expected=PINKY_BASH_${next}"
else
v2/bin/pinky-send-chatgpt "NARF failed=true id=PINKY_BASH_${id} exit=${rc} expected=PINKY_BASH_${next}"
fi
sleep 1
else
sleep 1
fi
done
