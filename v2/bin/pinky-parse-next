#!/usr/bin/env bash
set -euo pipefail
id="${1:?usage: pinky-parse-next ID < chat-text}"
start="PINKY_BASH_${id}"
awk -v start="$start" 'BEGIN { in_block=0; found=0; done=0; body="" } done { next } $0 == start { in_block=1; found=1; body=""; next } in_block && $0 == "PINKY_BASH_END" { if (body == "") { code=3; done=1; next } sub(/\n$/, "", body); print body; code=0; done=1; in_block=0; next } in_block { body = body $0 "\n"; next } END { if (done) exit code; if (!found) exit 1; if (in_block) exit 2; exit 1 }'
