#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/../.."
if [ -f runtime/.run/listener.pid ]; then
pid="$(cat runtime/.run/listener.pid 2>/dev/null || true)"
if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then kill "$pid" 2>/dev/null || true; fi
rm -f runtime/.run/listener.pid
fi
printf "stopped\n"
