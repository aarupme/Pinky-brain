#!/usr/bin/env bash
set -euo pipefail
osascript -e 'tell application "ChatGPT" to activate' -e 'delay 0.4' -e 'tell application "System Events"' -e 'tell process "ChatGPT"' -e 'set frontmost to true' -e 'delay 0.2' -e 'set outText to ""' -e 'set uiList to entire contents of window 1' -e 'repeat with itemRef in uiList' -e 'set roleText to ""' -e 'set descText to ""' -e 'set valueText to ""' -e 'try' -e 'set roleText to value of attribute "AXRole" of itemRef as text' -e 'end try' -e 'try' -e 'set descText to description of itemRef as text' -e 'end try' -e 'try' -e 'set valueText to value of itemRef as text' -e 'end try' -e 'if roleText is "AXStaticText" and descText is not "" and descText is not "text" and descText is not "button" and descText is not "group" and descText is not "heading" then' -e 'set outText to outText & descText & linefeed' -e 'end if' -e 'if roleText is "AXTextArea" and valueText is not "" then' -e 'set outText to outText & valueText & linefeed' -e 'end if' -e 'end repeat' -e 'return outText' -e 'end tell' -e 'end tell'
