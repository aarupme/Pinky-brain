#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/../.."
mkdir -p runtime/.run
on_stop() {
id="$(cat runtime/.run/expected-id 2>/dev/null || printf 0001)"
runtime/bin/pinky-send-chatgpt "Pinky stopped expected=PINKY_BASH_${id}" || true
printf "\nPINKY_BRAIN_STOPPED expected=PINKY_BASH_%s\n" "$id"
exit 0
}
trap on_stop INT TERM
printf "\nPINKY_BRAIN_CONSOLE_LISTENING\n"
while true; do
id="$(cat runtime/.run/expected-id 2>/dev/null || printf 0001)"
raw="$(runtime/bin/pinky-read-chatgpt || true)"
if printf "%s\n" "$raw" | runtime/bin/pinky-parse-next "$id" > runtime/.run/current-command.sh; then
if [ ! -s runtime/.run/current-command.sh ]; then sleep 1; continue; fi
runtime/bin/pinky-normalize-command runtime/.run/current-command.sh
chmod +x runtime/.run/current-command.sh
printf "\nPINKY_RUNNING_%s\n" "$id"
printf "\n--- command ---\n"
cat runtime/.run/current-command.sh
printf "\n--- output ---\n"
set +e
bash runtime/.run/current-command.sh 2>&1 | tee runtime/.run/terminal-output.txt
rc="${PIPESTATUS[0]}"
set -e
printf "\nPINKY_DONE_%s:%s\n" "$id" "$rc"
next="$(printf "%04d" "$((10#$id + 1))")"
if [ -f runtime/.run/stop-request ]; then
rm -f runtime/.run/stop-request
printf "%s\n" "$next" > runtime/.run/expected-id
runtime/bin/pinky-send-chatgpt "Pinky stopped expected=PINKY_BASH_${next}" || true
printf "\nPINKY_BRAIN_STOPPED expected=PINKY_BASH_%s\n" "$next"
exit 0
fi
printf "%s\n" "$next" > runtime/.run/expected-id
if [ "$rc" -eq 0 ]; then
runtime/bin/pinky-send-chatgpt "Narf! expected=PINKY_BASH_${next}"
else
runtime/bin/pinky-send-chatgpt "NARF failed=true id=PINKY_BASH_${id} exit=${rc} expected=PINKY_BASH_${next}"
fi
sleep 1
else
sleep 1
fi
done
