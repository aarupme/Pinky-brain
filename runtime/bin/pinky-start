#!/usr/bin/env bash
set -euo pipefail
cd "$(dirname "$0")/../.."
mkdir -p runtime/.run
if [ -f runtime/.run/listener.pid ]; then
  pid="$(cat runtime/.run/listener.pid 2>/dev/null || true)"
  if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then kill "$pid" 2>/dev/null || true; fi
  rm -f runtime/.run/listener.pid
fi
printf "0001\n" > runtime/.run/expected-id
boot_message="Pinky started expected=PINKY_BASH_0001"

if [ -f runtime/boot/launch-message.txt ]; then
  boot_message="$(cat runtime/boot/launch-message.txt)"

  boot_message="${boot_message}

Pinky started expected=PINKY_BASH_0001"
fi

runtime/bin/pinky-send-chatgpt "$boot_message" || true
exec runtime/bin/pinky-listen
