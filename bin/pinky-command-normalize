#!/usr/bin/env python3
import sys
import re

s = sys.stdin.read()
replacements = {
    chr(0x2018): chr(39),
    chr(0x2019): chr(39),
    chr(0x201C): chr(34),
    chr(0x201D): chr(34),
    chr(0x2013): chr(45),
    chr(0x2014): chr(45),
    chr(0x2010): chr(45),
    chr(0x2011): chr(45),
    bytes([0xC3,0xA2,0xC2,0x80,0xC2,0x98]).decode("utf-8"): chr(39),
    bytes([0xC3,0xA2,0xC2,0x80,0xC2,0x99]).decode("utf-8"): chr(39),
    bytes([0xC3,0xA2,0xC2,0x80,0xC2,0x9C]).decode("utf-8"): chr(34),
    bytes([0xC3,0xA2,0xC2,0x80,0xC2,0x9D]).decode("utf-8"): chr(34),
    bytes([0xC3,0xA2,0xC2,0x80,0xC2,0x93]).decode("utf-8"): chr(45),
    bytes([0xC3,0xA2,0xC2,0x80,0xC2,0x94]).decode("utf-8"): chr(45),
}
for dash in (chr(0x2013), chr(0x2014)):
    s = re.sub("(^|\\s)" + re.escape(dash) + "([a-z][a-z0-9-]{2,})", r"\1--\2", s)
    s = re.sub("(^|\\s)" + re.escape(dash) + "([A-Z][A-Za-z0-9-]*)", r"\1-\2", s)
for old, new in replacements.items():
    s = s.replace(old, new)
sys.stdout.write(s)
