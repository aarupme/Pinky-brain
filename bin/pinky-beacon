#!/usr/bin/env python3
import os
import tkinter as tk
from dataclasses import dataclass

os.environ["TK_SILENCE_DEPRECATION"] = "1"


@dataclass(frozen=True)
class BeaconState:
    key: str
    icon: str
    label: str
    glow: str
    surface: str
    text: str


STATES = {
    "idle": BeaconState("idle", "○", "Idle", "#6b7280", "#111827", "#d1d5db"),
    "pinky": BeaconState("pinky", "🐭", "Pinky Active", "#22c55e", "#052e16", "#ecfdf5"),
    "brain": BeaconState("brain", "🧠", "Brain Needed", "#8b5cf6", "#11102a", "#f5f3ff"),
    "paused": BeaconState("paused", "⏸", "Paused", "#f59e0b", "#221406", "#fffbeb"),
    "stopped": BeaconState("stopped", "🛑", "Stopped", "#ef4444", "#220707", "#fef2f2"),
}

STATE_ORDER = ["idle", "pinky", "brain", "paused", "stopped"]


class PinkyBeacon:
    def __init__(self) -> None:
        self.root = tk.Tk()
        self.root.withdraw()
        self.root.title("Pinky Brain")
        self.root.resizable(False, False)

        self.screen_width = self.root.winfo_screenwidth()
        self.screen_height = self.root.winfo_screenheight()

        self.outer_gap = 10
        self.column_gap = 14
        self.row_gap = 28
        self.menu_safe_top = 36
        self.dock_safe_bottom = 78

        self.chat_width = int(self.screen_width * 0.6) - self.outer_gap
        self.right_left = self.chat_width + self.column_gap
        self.right_width = self.screen_width - self.right_left - self.outer_gap

        self.usable_top = self.menu_safe_top
        self.usable_bottom = self.screen_height - self.dock_safe_bottom
        self.usable_height = self.usable_bottom - self.usable_top

        self.terminal_height = int(self.usable_height * 0.42)

        self.width = self.right_width
        self.height = int(self.usable_height * 0.38)
        self.x = self.right_left
        self.y = self.usable_top + self.terminal_height + self.row_gap

        self.state_index = 0

        self.root.geometry(f"{self.width}x{self.height}+{self.x}+{self.y}")
        self.root.configure(bg="#000001")
        self.root.overrideredirect(True)
        self.root.attributes("-topmost", False)

        try:
            self.root.attributes("-transparentcolor", "#000001")
        except tk.TclError:
            pass

        try:
            self.root.attributes("-alpha", 0.94)
        except tk.TclError:
            pass

        self.canvas = tk.Canvas(
            self.root,
            width=self.width,
            height=self.height,
            bd=0,
            highlightthickness=0,
            relief="flat",
            bg="#000001",
        )
        self.canvas.pack(fill="both", expand=True)

        self.root.bind("<Escape>", lambda _event: self.root.destroy())
        self.root.bind("<Button-1>", lambda _event: self.next_state())
        self.root.bind("1", lambda _event: self.set_state("idle"))
        self.root.bind("2", lambda _event: self.set_state("pinky"))
        self.root.bind("3", lambda _event: self.set_state("brain"))
        self.root.bind("4", lambda _event: self.set_state("paused"))
        self.root.bind("5", lambda _event: self.set_state("stopped"))

        self.set_state("idle")
        self.root.deiconify()
        self.root.lift()

    def _draw_panel(self, state: BeaconState) -> None:
        self.canvas.delete("all")

        w = self.width
        h = self.height
        margin = 18

        self.canvas.create_rectangle(
            margin + 8,
            margin + 8,
            w - margin + 8,
            h - margin + 8,
            fill=state.glow,
            outline="",
        )

        self.canvas.create_rectangle(
            margin,
            margin,
            w - margin,
            h - margin,
            fill=state.surface,
            outline=state.glow,
            width=3,
        )

        self.canvas.create_text(
            w / 2,
            h * 0.28,
            text=state.icon,
            fill=state.text,
            font=("Apple Color Emoji", 78),
        )

        self.canvas.create_text(
            w / 2,
            h * 0.54,
            text=state.label,
            fill=state.text,
            font=("Helvetica Neue", 28, "bold"),
        )

        self.canvas.create_text(
            w / 2,
            h * 0.68,
            text="Pinky Brain Workspace",
            fill=state.text,
            font=("Helvetica Neue", 15),
        )

        self.canvas.create_text(
            w / 2,
            h * 0.81,
            text="Click cycles states · Esc closes",
            fill=state.text,
            font=("Helvetica Neue", 12),
        )

        self.canvas.create_oval(
            w - margin - 26,
            margin + 18,
            w - margin - 8,
            margin + 36,
            fill=state.glow,
            outline="",
        )

    def set_state(self, state_key: str) -> None:
        self.state_index = STATE_ORDER.index(state_key)
        self._draw_panel(STATES[state_key])

    def next_state(self) -> None:
        self.state_index = (self.state_index + 1) % len(STATE_ORDER)
        self.set_state(STATE_ORDER[self.state_index])

    def run(self) -> None:
        self.root.mainloop()


if __name__ == "__main__":
    PinkyBeacon().run()
