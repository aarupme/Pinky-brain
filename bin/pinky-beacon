#!/usr/bin/env python3
import tkinter as tk
from dataclasses import dataclass


@dataclass(frozen=True)
class BeaconState:
    key: str
    icon: str
    label: str
    glow: str
    surface: str
    text: str


STATES = {
    "idle": BeaconState("idle", "○", "Idle", "#6b7280", "#111827", "#d1d5db"),
    "pinky": BeaconState("pinky", "🐭", "Pinky Active", "#22c55e", "#052e16", "#ecfdf5"),
    "brain": BeaconState("brain", "🧠", "Brain Needed", "#8b5cf6", "#11102a", "#f5f3ff"),
    "paused": BeaconState("paused", "⏸", "Paused", "#f59e0b", "#221406", "#fffbeb"),
    "stopped": BeaconState("stopped", "🛑", "Stopped", "#ef4444", "#220707", "#fef2f2"),
}

STATE_ORDER = ["idle", "pinky", "brain", "paused", "stopped"]


class PinkyBeacon:
    def __init__(self) -> None:
        self.width = 260
        self.height = 92
        self.radius = 30
        self.state_index = 0

        self.root = tk.Tk()
        self.root.withdraw()
        self.root.title("")
        self.root.resizable(False, False)
        self.root.configure(bg="#000001")

        self.root.overrideredirect(True)
        self.root.geometry(self._top_center_geometry(self.width, self.height))

        try:
            self.root.attributes("-transparentcolor", "#000001")
        except tk.TclError:
            pass

        try:
            self.root.attributes("-alpha", 0.97)
        except tk.TclError:
            pass

        self.root.attributes("-topmost", True)

        self.canvas = tk.Canvas(
            self.root,
            width=self.width,
            height=self.height,
            bd=0,
            highlightthickness=0,
            relief="flat",
            bg="#000001",
        )
        self.canvas.pack(fill="both", expand=True)

        self.root.bind("<Escape>", lambda _event: self.root.destroy())
        self.root.bind("<Button-1>", lambda _event: self.next_state())
        self.root.bind("1", lambda _event: self.set_state("idle"))
        self.root.bind("2", lambda _event: self.set_state("pinky"))
        self.root.bind("3", lambda _event: self.set_state("brain"))
        self.root.bind("4", lambda _event: self.set_state("paused"))
        self.root.bind("5", lambda _event: self.set_state("stopped"))

        self.set_state("idle")

        self.root.deiconify()
        self.root.lift()
        self.root.after(100, self._force_frameless)
        self._keep_above()

    def _force_frameless(self) -> None:
        try:
            self.root.overrideredirect(True)
            self.root.attributes("-topmost", True)
            self.root.lift()
        except tk.TclError:
            pass

    def _keep_above(self) -> None:
        try:
            self.root.attributes("-topmost", True)
            self.root.lift()
        except tk.TclError:
            return
        self.root.after(500, self._keep_above)

    def _top_center_geometry(self, width: int, height: int) -> str:
        screen_width = self.root.winfo_screenwidth()
        x = int((screen_width - width) / 2)
        y = 0
        return f"{width}x{height}+{x}+{y}"

    def _draw_halfmoon(self, state: BeaconState) -> None:
        self.canvas.delete("all")

        w = self.width
        h = self.height
        r = self.radius
        bottom = h - 6

        self.canvas.create_oval(
            24,
            12,
            w - 24,
            bottom + 22,
            fill=state.glow,
            outline="",
        )

        self.canvas.create_rectangle(
            0,
            0,
            w,
            bottom - r,
            fill=state.surface,
            outline="",
        )
        self.canvas.create_rectangle(
            r,
            0,
            w - r,
            bottom,
            fill=state.surface,
            outline="",
        )
        self.canvas.create_arc(
            0,
            bottom - (2 * r),
            2 * r,
            bottom,
            start=180,
            extent=90,
            fill=state.surface,
            outline="",
        )
        self.canvas.create_arc(
            w - (2 * r),
            bottom - (2 * r),
            w,
            bottom,
            start=270,
            extent=90,
            fill=state.surface,
            outline="",
        )
        self.canvas.create_rectangle(
            r,
            bottom - r,
            w - r,
            bottom,
            fill=state.surface,
            outline="",
        )

        self.canvas.create_text(
            78,
            47,
            text=state.icon,
            fill=state.text,
            font=("Apple Color Emoji", 34),
        )

        self.canvas.create_text(
            164,
            43,
            text=state.label,
            fill=state.text,
            font=("Helvetica Neue", 16, "bold"),
        )

        self.canvas.create_oval(
            w - 28,
            14,
            w - 16,
            26,
            fill=state.glow,
            outline="",
        )

    def set_state(self, state_key: str) -> None:
        self.state_index = STATE_ORDER.index(state_key)
        self._draw_halfmoon(STATES[state_key])

    def next_state(self) -> None:
        self.state_index = (self.state_index + 1) % len(STATE_ORDER)
        self.set_state(STATE_ORDER[self.state_index])

    def run(self) -> None:
        self.root.mainloop()


if __name__ == "__main__":
    PinkyBeacon().run()
