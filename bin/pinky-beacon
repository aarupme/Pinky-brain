#!/usr/bin/env python3
import os
import subprocess
import tkinter as tk
from dataclasses import dataclass

os.environ["TK_SILENCE_DEPRECATION"] = "1"


@dataclass(frozen=True)
class BeaconState:
    key: str
    icon: str
    label: str
    glow: str
    surface: str
    text: str


STATES = {
    "idle": BeaconState("idle", "💤", "Idle", "#6b7280", "#111827", "#d1d5db"),
    "watching": BeaconState("watching", "👀", "Watching", "#38bdf8", "#071923", "#e0f2fe"),
    "reading": BeaconState("reading", "📖", "Reading", "#60a5fa", "#0b1220", "#dbeafe"),
    "pinky": BeaconState("pinky", "🐭", "Narf Ready", "#22c55e", "#052e16", "#ecfdf5"),
    "brain": BeaconState("brain", "🧠", "Brain Needed", "#8b5cf6", "#11102a", "#f5f3ff"),
    "toolbox": BeaconState("toolbox", "🧰", "Toolbox", "#c084fc", "#1b1028", "#faf5ff"),
    "executing": BeaconState("executing", "⚡", "Executing", "#facc15", "#221406", "#fefce8"),
    "done": BeaconState("done", "✅", "Done", "#22c55e", "#052e16", "#ecfdf5"),
    "duplicate": BeaconState("duplicate", "🔁", "Duplicate", "#fb923c", "#241300", "#ffedd5"),
    "blocked": BeaconState("blocked", "🛑", "Blocked", "#ef4444", "#220707", "#fef2f2"),
    "paused": BeaconState("paused", "⏸", "Paused", "#f59e0b", "#221406", "#fffbeb"),
    "stopped": BeaconState("stopped", "🛑", "Stopped", "#ef4444", "#220707", "#fef2f2"),
}

STATE_ORDER = ["idle", "watching", "reading", "pinky", "brain", "toolbox", "executing", "done", "duplicate", "blocked", "paused", "stopped"]


class PinkyBeacon:
    def __init__(self) -> None:
        self.root = tk.Tk()
        self.root.withdraw()
        self.root.title("Pinky Brain")
        self.root.resizable(False, False)

        self.screen_width = self.root.winfo_screenwidth()
        self.screen_height = self.root.winfo_screenheight()

        self.outer_gap = 10
        self.column_gap = 14
        self.row_gap = 28
        self.menu_safe_top = 36
        self.dock_safe_bottom = 78

        self.chat_width = int(self.screen_width * 0.6) - self.outer_gap
        self.right_left = self.chat_width + self.column_gap
        self.right_width = self.screen_width - self.right_left - self.outer_gap

        self.usable_top = self.menu_safe_top
        self.usable_bottom = self.screen_height - self.dock_safe_bottom
        self.usable_height = self.usable_bottom - self.usable_top

        self.terminal_height = int(self.usable_height * 0.42)

        self.width = self.right_width
        self.height = int(self.usable_height * 0.38)
        self.x = self.right_left
        self.y = self.usable_top + self.terminal_height + self.row_gap

        self.state_index = 0
        self.current_state_key = None
        self.brain_alert_latched = False
        self.last_brain_alert_token = ""
        self.sound_brain_path = os.path.join(os.path.dirname(__file__), "pinky-sound-brain")
        self.beacon_state_file = os.path.join(os.path.dirname(os.path.dirname(__file__)), ".run", "pinky-beacon.state")
        self.beacon_alert_file = os.path.join(os.path.dirname(os.path.dirname(__file__)), ".run", "pinky-beacon.alert")

        self.root.geometry(f"{self.width}x{self.height}+{self.x}+{self.y}")
        self.root.configure(bg="#000001")
        self.root.overrideredirect(True)
        self.root.attributes("-topmost", False)

        try:
            self.root.attributes("-transparentcolor", "#000001")
        except tk.TclError:
            pass

        try:
            self.root.attributes("-alpha", 0.94)
        except tk.TclError:
            pass

        self.canvas = tk.Canvas(
            self.root,
            width=self.width,
            height=self.height,
            bd=0,
            highlightthickness=0,
            relief="flat",
            bg="#000001",
        )
        self.canvas.pack(fill="both", expand=True)

        self.root.bind("<Escape>", lambda _event: self.root.destroy())
        self.root.bind("<Button-1>", lambda _event: self.next_state())
        self.root.bind("1", lambda _event: self.set_state("idle"))
        self.root.bind("2", lambda _event: self.set_state("pinky"))
        self.root.bind("3", lambda _event: self.set_state("brain"))
        self.root.bind("4", lambda _event: self.set_state("paused"))
        self.root.bind("5", lambda _event: self.set_state("stopped"))

        self.set_state("idle")
        self._poll_state_file()
        self.root.deiconify()
        self.root.lift()

    def _draw_panel(self, state: BeaconState) -> None:
        self.canvas.delete("all")

        w = self.width
        h = self.height
        margin = 18

        self.canvas.create_rectangle(
            margin + 8,
            margin + 8,
            w - margin + 8,
            h - margin + 8,
            fill=state.glow,
            outline="",
        )

        self.canvas.create_rectangle(
            margin,
            margin,
            w - margin,
            h - margin,
            fill=state.surface,
            outline=state.glow,
            width=3,
        )

        self.canvas.create_text(
            w / 2,
            h * 0.28,
            text=state.icon,
            fill=state.text,
            font=("Apple Color Emoji", 78),
        )

        self.canvas.create_text(
            w / 2,
            h * 0.54,
            text=state.label,
            fill=state.text,
            font=("Helvetica Neue", 28, "bold"),
        )

        self.canvas.create_text(
            w / 2,
            h * 0.68,
            text="Pinky Brain Workspace",
            fill=state.text,
            font=("Helvetica Neue", 15),
        )

        self.canvas.create_text(
            w / 2,
            h * 0.81,
            text="Click cycles states · Esc closes",
            fill=state.text,
            font=("Helvetica Neue", 12),
        )

        self.canvas.create_oval(
            w - margin - 26,
            margin + 18,
            w - margin - 8,
            margin + 36,
            fill=state.glow,
            outline="",
        )

    def set_state(self, state_key: str) -> None:
        if state_key not in STATES:
            return

        previous_state_key = self.current_state_key
        self.current_state_key = state_key
        self.state_index = STATE_ORDER.index(state_key)
        self._draw_panel(STATES[state_key])

        if state_key == "brain":
            alert_token = self._read_alert_token()
            if alert_token and alert_token != self.last_brain_alert_token:
                self._play_brain_sound()
                self.last_brain_alert_token = alert_token
                self.brain_alert_latched = True
            elif previous_state_key != "brain" and not self.brain_alert_latched:
                self._play_brain_sound()
                self.brain_alert_latched = True
        elif state_key in {"pinky", "toolbox", "executing", "done", "blocked", "paused", "stopped"}:
            self.brain_alert_latched = False

    def _poll_state_file(self) -> None:
        try:
            with open(self.beacon_state_file, "r", encoding="utf-8") as file:
                requested_state = file.read().strip()
        except OSError:
            requested_state = ""

        if requested_state in STATES and requested_state != self.current_state_key:
            self.set_state(requested_state)

        self.root.after(500, self._poll_state_file)

    def _read_alert_token(self) -> str:
        try:
            with open(self.beacon_alert_file, "r", encoding="utf-8") as file:
                return file.read().strip()
        except OSError:
            return ""

    def _play_brain_sound(self) -> None:
        try:
            subprocess.Popen(
                [self.sound_brain_path],
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
            )
        except OSError:
            pass

    def next_state(self) -> None:
        self.state_index = (self.state_index + 1) % len(STATE_ORDER)
        self.set_state(STATE_ORDER[self.state_index])

    def run(self) -> None:
        self.root.mainloop()


if __name__ == "__main__":
    PinkyBeacon().run()
