#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CANDIDATE_FILE="$ROOT_DIR/.run/pinky-command.candidate"
if [[ ! -s "$CANDIDATE_FILE" ]]; then
  echo "classification=none"
  echo "reason=no-candidate"
  exit 0
fi
command_text="$(cat "$CANDIDATE_FILE")"
case "$command_text" in
  cd\ ~/Desktop/pinky-brain\ \&\&\ ./bin/pinky-loop\ status|cd\ ~/Desktop/pinky-brain\ \&\&\ ./bin/pinky-beacon-status|cd\ ~/Desktop/pinky-brain\ \&\&\ ./bin/pinky-command-detect|cd\ ~/Desktop/pinky-brain\ \&\&\ ./bin/pinky-command-extract|cd\ ~/Desktop/pinky-brain\ \&\&\ ./bin/pinky-status)
    echo "classification=safe"
    echo "reason=allowed-local-status-command"
    exit 0
    ;;
esac
case "$command_text" in
  *sudo*|*\ rm\ *|rm\ *|*curl*\|*sh*|*chmod\ *|*chown\ *|*\>\ /dev/*|*mkfs*|*diskutil*)
    echo "classification=blocked"
    echo "reason=dangerous-command-pattern"
    exit 0
    ;;
esac
case "$command_text" in
  *git\ push*|*git\ commit*|*npm\ install*|*pnpm\ install*|*yarn\ add*|*brew\ install*|*pip\ install*|*deploy*|*migration*|*schema*)
    echo "classification=brain_required"
    echo "reason=high-impact-command-pattern"
    exit 0
    ;;
esac
case "$command_text" in
  cd\ ~/Desktop/pinky-brain\ \&\&\ *)
    echo "classification=brain_required"
    echo "reason=unrecognized-project-command"
    exit 0
    ;;
  *)
    echo "classification=blocked"
    echo "reason=outside-project-or-invalid-prefix"
    exit 0
    ;;
esac
