#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TMP_FILE="$(mktemp)"
SIGNAL_FILE="$(mktemp)"
CONTEXT_FILE="$(mktemp)"
trap 'rm -f "$TMP_FILE" "$SIGNAL_FILE" "$CONTEXT_FILE"' EXIT

set +e
"$ROOT_DIR/bin/pinky-read-visible" > "$TMP_FILE" 2>&1
read_status="$?"
set -e

if [[ "$read_status" -ne 0 ]]; then
  echo "pinky-detect-signal error: failed to read visible ChatGPT text" >&2
  exit 1
fi

latest_signal=""
latest_line_no=""
line_no=0
while IFS= read -r line; do
  line_no=$((line_no + 1))
  cleaned="$(printf "%s" "$line" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
  case "$cleaned" in
    "🐭") latest_signal="pinky"; latest_line_no="$line_no" ;;
    "🧠"|"<0001f9e0>") latest_signal="brain"; latest_line_no="$line_no" ;;
    "🛑") latest_signal="stop"; latest_line_no="$line_no" ;;
  esac
done < "$TMP_FILE"

case "$latest_signal" in
  pinky|brain|stop)
    printf "%s\n" "$latest_signal" > "$SIGNAL_FILE"
    printf "%s:%s\n" "$latest_signal" "$latest_line_no" > "$CONTEXT_FILE"
    ;;
esac

if [[ -s "$SIGNAL_FILE" ]]; then
  signal="$(tail -1 "$SIGNAL_FILE")"
  context="$(tail -1 "$CONTEXT_FILE")"
  hash="$(printf "%s" "$context" | shasum -a 256 | awk '{print $1}')"
  echo "signal=$signal"
  echo "signal_hash=$hash"
else
  echo "signal=none"
  echo "signal_hash=none"
fi
