#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TMP_FILE="$(mktemp)"
SIGNAL_FILE="$(mktemp)"
CONTEXT_FILE="$(mktemp)"
trap 'rm -f "$TMP_FILE" "$SIGNAL_FILE" "$CONTEXT_FILE"' EXIT

set +e
"$ROOT_DIR/bin/pinky-read-visible" > "$TMP_FILE" 2>&1
read_status="$?"
set -e

if [[ "$read_status" -ne 0 ]]; then
  echo "pinky-detect-signal error: failed to read visible ChatGPT text" >&2
  exit 1
fi

signal_count=0

while IFS= read -r line; do
  cleaned="$(printf "%s" "$line" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"

  case "$cleaned" in
    "🐭")
      signal_count=$((signal_count + 1))
      printf "%s\n" "pinky" > "$SIGNAL_FILE"
      printf "%s|%s\n" "$signal_count" "$cleaned" > "$CONTEXT_FILE"
      ;;
    "🧠"|"<0001f9e0>")
      signal_count=$((signal_count + 1))
      printf "%s\n" "brain" > "$SIGNAL_FILE"
      printf "%s|%s\n" "$signal_count" "$cleaned" > "$CONTEXT_FILE"
      ;;
    "🛑")
      signal_count=$((signal_count + 1))
      printf "%s\n" "stop" > "$SIGNAL_FILE"
      printf "%s|%s\n" "$signal_count" "$cleaned" > "$CONTEXT_FILE"
      ;;
  esac
done < <(tail -120 "$TMP_FILE")

if [[ -s "$SIGNAL_FILE" ]]; then
  signal="$(tail -1 "$SIGNAL_FILE")"
  context="$(tail -1 "$CONTEXT_FILE")"
  hash="$(printf "%s" "$context" | shasum -a 256 | awk '{print $1}')"
  echo "signal=$signal"
  echo "signal_hash=$hash"
else
  echo "signal=none"
  echo "signal_hash=none"
fi
