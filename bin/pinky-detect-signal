#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TMP_FILE="$(mktemp)"
SIGNAL_FILE="$(mktemp)"
CONTEXT_FILE="$(mktemp)"
trap 'rm -f "$TMP_FILE" "$SIGNAL_FILE" "$CONTEXT_FILE" "$CONTEXT_FILE.block"' EXIT

READ_VISIBLE="${PINKY_READ_VISIBLE:-$ROOT_DIR/bin/pinky-read-visible}"

set +e
"$READ_VISIBLE" > "$TMP_FILE" 2>&1
read_status="$?"
set -e

if [[ "$read_status" -ne 0 ]]; then
  echo "pinky-detect-signal error: failed to read visible ChatGPT text" >&2
  exit 1
fi

latest_signal=""
latest_line_no=""
line_no=0
block_start=0
prev_cleaned=""
while IFS= read -r line; do
  line_no=$((line_no + 1))
  cleaned="$(printf "%s" "$line" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
  if [[ "$prev_cleaned" == "text" && "$cleaned" == "text" ]]; then
    block_start="$line_no"
  fi
  prev_cleaned="$cleaned"
done < "$TMP_FILE"

line_no=0
while IFS= read -r line; do
  line_no=$((line_no + 1))
  if [[ "$line_no" -le "$block_start" ]]; then
    continue
  fi
  cleaned="$(printf "%s" "$line" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
  case "$cleaned" in
    "🐭") latest_signal="pinky"; latest_line_no="$line_no" ;;
    "🧠"|"<0001f9e0>") latest_signal="brain"; latest_line_no="$line_no" ;;
    "🛑") latest_signal="stop"; latest_line_no="$line_no" ;;
  esac
done < "$TMP_FILE"

case "$latest_signal" in
  pinky|brain|stop)
    printf "%s\n" "$latest_signal" > "$SIGNAL_FILE"
    awk -v start="$block_start" 'NR > start { print }' "$TMP_FILE" | shasum -a 256 | awk '{print $1}' > "$CONTEXT_FILE.block"
    block_hash="$(cat "$CONTEXT_FILE.block")"
    printf "%s:%s:%s:%s\n" "$latest_signal" "$block_start" "$latest_line_no" "$block_hash" > "$CONTEXT_FILE"
    ;;
esac

if [[ -s "$SIGNAL_FILE" ]]; then
  signal="$(tail -1 "$SIGNAL_FILE")"
  context="$(tail -1 "$CONTEXT_FILE")"
  hash="$(printf "%s" "$context" | shasum -a 256 | awk '{print $1}')"
  echo "signal=$signal"
  echo "signal_hash=$hash"
else
  echo "signal=none"
  echo "signal_hash=none"
fi
