#!/usr/bin/env bash
set -euo pipefail
cd ~/Desktop/pinky-brain
echo "PINKY cockpit status"
echo
git --no-pager status --short --branch
echo
echo "--- latest commit ---"
git --no-pager log --oneline -1
echo
echo "--- latest transport log ---"
ls -t logs/transport-runs/*.log 2>/dev/null | head -2 | tail -1 || true
echo
echo "--- latest transport output ---"
latest=$(ls -t logs/transport-runs/*.log 2>/dev/null | head -2 | tail -1 || true)
if [[ -n "$latest" ]]; then tail -40 "$latest"; else echo "no transport logs"; fi
echo
echo "--- send callback tail ---"
tail -8 logs/pinky-send.log 2>/dev/null || true
