#!/usr/bin/env bash
set -euo pipefail
cd ~/Desktop/pinky-brain
echo "PINKY cockpit status v2"
echo "--- repo ---"
git --no-pager status --short --branch
echo "--- preflight ---"
./bin/pinky-preflight
echo "--- disk/logs ---"
du -sh logs .run 2>/dev/null || true
df -h .
echo "--- latest commit ---"
git --no-pager log --oneline -1
echo "--- latest completed transport log ---"
latest=$(ls -t logs/transport-runs/*.log 2>/dev/null | head -2 | tail -1 || true)
if [[ -n "$latest" ]]; then echo "$latest"; wc -c "$latest"; tail -20 "$latest"; else echo "no completed transport logs"; fi
echo "--- send callback tail ---"
tail -6 logs/pinky-send.log 2>/dev/null || true
echo "PINKY cockpit status v2 done"
