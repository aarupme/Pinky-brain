#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
RUN_DIR="$ROOT_DIR/.run"
PID_FILE="$RUN_DIR/pinky-workhorse.pid"
cd "$ROOT_DIR"
if [[ -f "$PID_FILE" ]]; then
  pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [[ -n "$pid" ]] && kill -0 "$pid" 2>/dev/null; then
    echo "workhorse=running pid=$pid"
  else
    echo "workhorse=stale pid=$pid"
  fi
else
  echo "workhorse=stopped pid=none"
fi
"$ROOT_DIR/bin/pinky-status"
