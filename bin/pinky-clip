#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMMAND_FILE="$ROOT_DIR/.run/pinky-courier.command"
command_text="$(pbpaste)"
[[ -n "${command_text//[[:space:]]/}" ]] || { printf "PINKY-CLIP failed=true reason=empty-clipboard\n" >&2; exit 2; }
case "$command_text" in
  cd\ ~/Desktop/pinky-brain*|cd\ "$HOME/Desktop/pinky-brain"*|cd\ /Users/*/Desktop/pinky-brain*) ;;
  *) printf "PINKY-CLIP failed=true reason=clipboard-command-must-start-in-pinky-brain\n" >&2; exit 2 ;;
esac
mkdir -p "$ROOT_DIR/.run"
printf "%s\n" "$command_text" > "$COMMAND_FILE"
"$ROOT_DIR/bin/pinky-courier"
