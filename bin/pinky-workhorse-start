#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
RUN_DIR="$ROOT_DIR/.run"
LOG_DIR="$ROOT_DIR/logs"
PID_FILE="$RUN_DIR/pinky-workhorse.pid"
LOG_FILE="$LOG_DIR/pinky-workhorse.log"
SLEEP_SECONDS="${PINKY_WORKHORSE_SLEEP_SECONDS:-0.2}"
COMMAND_FILE="$RUN_DIR/pinky-code-editor-command.txt"
cd "$ROOT_DIR"
mkdir -p "$RUN_DIR" "$LOG_DIR"
if [[ -f "$RUN_DIR/pinky-cockpit-watch.pid" ]]; then
  watcher_pid="$(cat "$RUN_DIR/pinky-cockpit-watch.pid" 2>/dev/null || true)"
  if [[ -n "$watcher_pid" ]] && kill -0 "$watcher_pid" 2>/dev/null; then
    kill "$watcher_pid" 2>/dev/null || true
    sleep 0.5
  fi
fi
rm -f "$RUN_DIR/pinky-cockpit-watch.pid" "$RUN_DIR/pinky-cockpit-watch.lock"
if [[ -f "$PID_FILE" ]]; then
  old_pid="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [[ -n "$old_pid" ]] && kill -0 "$old_pid" 2>/dev/null; then
    echo "PINKY workhorse already running pid=$old_pid"
    exit 0
  fi
  rm -f "$PID_FILE"
fi
rm -f "$RUN_DIR/pinky-command.candidate" "$RUN_DIR/pinky-command.candidate.classification" "$RUN_DIR/pinky-command.candidate.reason" "$RUN_DIR/pinky-transport.input" "$RUN_DIR/pinky-command.last-hash"
: > "$COMMAND_FILE"
"$ROOT_DIR/bin/pinky-set-state" stopped >/dev/null
nohup "$ROOT_DIR/bin/pinky-cockpit-watch" --sleep "$SLEEP_SECONDS" >> "$LOG_FILE" 2>&1 &
pid="$!"
printf "%s\n" "$pid" > "$PID_FILE"
sleep 0.5
if kill -0 "$pid" 2>/dev/null; then
  echo "PINKY workhorse started pid=$pid log=$LOG_FILE"
else
  echo "PINKY workhorse failed to start; see $LOG_FILE" >&2
  exit 1
fi
