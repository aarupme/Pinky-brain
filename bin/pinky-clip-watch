#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUN_DIR="$ROOT_DIR/.run"
STOP_FILE="$RUN_DIR/pinky-clip-watch.stop"
LAST_HASH_FILE="$RUN_DIR/pinky-clip-watch.last-hash"
mkdir -p "$RUN_DIR"
PID_FILE="$RUN_DIR/pinky-clip-watch.pid"
LOG_FILE="$ROOT_DIR/logs/pinky-clip-watch.log"
mkdir -p "$ROOT_DIR/logs"

case "${1:-}" in
  start)
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" >/dev/null 2>&1; then
      printf "PINKY-CLIP-WATCH state=already-running pid=%s log=%s\n" "$(cat "$PID_FILE")" "$LOG_FILE"
      exit 0
    fi
    rm -f "$STOP_FILE"
    nohup "$0" run > "$LOG_FILE" 2>&1 &
    printf "%s\n" "$!" > "$PID_FILE"
    printf "PINKY-CLIP-WATCH state=started pid=%s log=%s\n" "$!" "$LOG_FILE"
    exit 0
    ;;
  stop)
    touch "$STOP_FILE"
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" >/dev/null 2>&1; then
      kill "$(cat "$PID_FILE")" >/dev/null 2>&1 || true
    fi
    rm -f "$PID_FILE"
    printf "PINKY-CLIP-WATCH state=stopped\n"
    exit 0
    ;;
  status)
    if [[ -f "$PID_FILE" ]] && kill -0 "$(cat "$PID_FILE")" >/dev/null 2>&1; then
      printf "PINKY-CLIP-WATCH state=running pid=%s log=%s\n" "$(cat "$PID_FILE")" "$LOG_FILE"
    else
      printf "PINKY-CLIP-WATCH state=stopped\n"
    fi
    exit 0
    ;;
  run|"") ;;
  *) printf "usage: pinky-clip-watch start|stop|status|run\n" >&2; exit 2 ;;
esac

rm -f "$STOP_FILE"
printf "PINKY-CLIP-WATCH state=watching\n"
while [[ ! -f "$STOP_FILE" ]]; do
  command_text="$(pbpaste || true)"
  if [[ -n "${command_text//[[:space:]]/}" ]]; then
    hash="$(printf "%s" "$command_text" | shasum -a 256 | awk "{print \$1}")"
    last_hash=""
    [[ -f "$LAST_HASH_FILE" ]] && last_hash="$(cat "$LAST_HASH_FILE")"
    if [[ "$hash" != "$last_hash" ]]; then
      case "$command_text" in
        cd\ ~/Desktop/pinky-brain*|cd\ "$HOME/Desktop/pinky-brain"*|cd\ /Users/*/Desktop/pinky-brain*)
          printf "%s\n" "$hash" > "$LAST_HASH_FILE"
          printf "%s\n" "$command_text" > "$RUN_DIR/pinky-courier.command"
          "$ROOT_DIR/bin/pinky-courier" || true
          ;;
      esac
    fi
  fi
  sleep 1
done
printf "PINKY-CLIP-WATCH exited\n"
