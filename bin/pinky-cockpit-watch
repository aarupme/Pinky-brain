#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUN_DIR="$ROOT_DIR/.run"
LAST_SUCCESS_HASH_FILE="$RUN_DIR/pinky-cockpit-watch.last-success-hash"
LAST_ATTEMPT_HASH_FILE="$RUN_DIR/pinky-cockpit-watch.last-attempt-hash"
SLEEP_SECONDS="${PINKY_SLEEP_SECONDS:-1}"
LOCK_DIR="$RUN_DIR/pinky-cockpit-watch.lock"
if ! mkdir "$LOCK_DIR" 2>/dev/null; then
  echo "PINKY cockpit refused: already running"
  exit 23
fi
trap 'rmdir "$LOCK_DIR"' EXIT

"$ROOT_DIR/bin/pinky-preflight"
mkdir -p "$RUN_DIR"

printf "PINKY cockpit state=watching\n"
printf "Narf!" > "$RUN_DIR/pinky-narf.txt"
"$ROOT_DIR/bin/pinky-send" --file "$RUN_DIR/pinky-narf.txt"

max_cycles="${PINKY_MAX_CYCLES:-0}"
cycle=0

while true; do
  set +e
  output="$("$ROOT_DIR/bin/pinky-command-extract" 2>&1)"
  extract_code="$?"
  set -e

  if [[ "$extract_code" -eq 0 && -s "$RUN_DIR/pinky-command.candidate" ]]; then
    command_text="$(cat "$RUN_DIR/pinky-command.candidate")"
    command_hash="$(printf "%s" "$command_text" | shasum -a 256 | cut -d " " -f 1)"

    last_success_hash=""
    last_attempt_hash=""
    [[ -s "$LAST_SUCCESS_HASH_FILE" ]] && last_success_hash="$(cat "$LAST_SUCCESS_HASH_FILE")"
    [[ -s "$LAST_ATTEMPT_HASH_FILE" ]] && last_attempt_hash="$(cat "$LAST_ATTEMPT_HASH_FILE")"

    if [[ -n "$command_text" && "$command_hash" != "$last_success_hash" && "$command_hash" != "$last_attempt_hash" ]]; then
      printf "%s\n" "$command_hash" > "$LAST_ATTEMPT_HASH_FILE"
      cp "$RUN_DIR/pinky-command.candidate" "$RUN_DIR/pinky-transport.input"

      "$ROOT_DIR/bin/pinky-preflight"

      set +e
      "$ROOT_DIR/bin/pinky-transport-once"
      run_code="$?"
      set -e

      if [[ "$run_code" -eq 0 ]]; then
        printf "%s\n" "$command_hash" > "$LAST_SUCCESS_HASH_FILE"
        printf "Narf!" > "$RUN_DIR/pinky-narf.txt"
        "$ROOT_DIR/bin/pinky-send" --file "$RUN_DIR/pinky-narf.txt"
      fi

      printf "PINKY cockpit state=watching last_exit=%s\n" "$run_code"
    fi
  fi

  cycle=$((cycle + 1))
  if [[ "$max_cycles" != "0" && "$cycle" -ge "$max_cycles" ]]; then
    printf "PINKY cockpit state=stopped reason=max_cycles cycles=%s\n" "$cycle"
    exit 0
  fi

  sleep "$SLEEP_SECONDS"
done
