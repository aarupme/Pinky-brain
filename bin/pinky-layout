#!/usr/bin/env python3
import os
import subprocess
import tkinter as tk

os.environ["TK_SILENCE_DEPRECATION"] = "1"


def get_screen_size() -> tuple[int, int]:
    root = tk.Tk()
    root.withdraw()
    width = root.winfo_screenwidth()
    height = root.winfo_screenheight()
    root.destroy()
    return width, height


def run_layout() -> None:
    screen_width, screen_height = get_screen_size()

    outer_gap = 10
    column_gap = 14
    row_gap = 28
    menu_safe_top = 36
    dock_safe_bottom = 78

    usable_top = menu_safe_top
    usable_bottom = screen_height - dock_safe_bottom
    usable_height = usable_bottom - usable_top

    chat_width = int(screen_width * 0.6) - outer_gap
    right_left = chat_width + column_gap
    right_width = screen_width - right_left - outer_gap

    terminal_height = int(usable_height * 0.42)
    terminal_top = usable_top

    applescript = f"""
tell application "ChatGPT"
  activate
end tell

delay 0.2

tell application "Terminal"
  activate
end tell

delay 0.2

tell application "System Events"
  if exists process "ChatGPT" then
    tell process "ChatGPT"
      if exists window 1 then
        set position of window 1 to {{0, {usable_top}}}
        set size of window 1 to {{{chat_width}, {usable_height}}}
      end if
    end tell
  end if

  if exists process "Terminal" then
    tell process "Terminal"
      if exists window 1 then
        set position of window 1 to {{{right_left}, {terminal_top}}}
        set size of window 1 to {{{right_width}, {terminal_height}}}
      end if
    end tell
  end if
end tell
"""

    result = subprocess.run(["osascript", "-e", applescript], text=True, capture_output=True, check=False)

    if result.returncode != 0:
        print(result.stderr.strip())
        raise SystemExit(result.returncode)

    print("Pinky workspace layout applied")


if __name__ == "__main__":
    run_layout()
