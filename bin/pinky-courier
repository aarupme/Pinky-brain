#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMMAND_FILE="$ROOT_DIR/.run/pinky-courier.command"
CANDIDATE_FILE="$ROOT_DIR/.run/pinky-command.candidate"

fail() {
  printf "PINKY-COURIER failed=true reason=%s\n" "$1"
  exit 1
}

[[ -s "$COMMAND_FILE" ]] || fail "missing-command-file"
command_text="$(cat "$COMMAND_FILE")"
[[ -n "$command_text" ]] || fail "empty-command"

printf "%s\n" "$command_text" > "$CANDIDATE_FILE"
set +e
run_output="$("$ROOT_DIR/bin/pinky-command-run" 2>&1)"
run_exit="$?"
set -e

hash="$(printf "%s\n" "$run_output" | awk -F= "/^candidate_hash=/{print \$2; exit}")"
output_file="$(printf "%s\n" "$run_output" | awk -F= "/^output_file=/{print \$2; exit}")"
reported_exit="$(printf "%s\n" "$run_output" | awk -F= "/^exit_code=/{print \$2; exit}")"
[[ -n "$reported_exit" ]] || reported_exit="$run_exit"


printf "PINKY-COURIER executed=true exit=%s log=%s hash=%s callback=disabled\n" "$reported_exit" "${output_file:-none}" "${hash:-no-hash}"

exit "$reported_exit"
