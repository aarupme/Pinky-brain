#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUN_DIR="$ROOT_DIR/.run"
LAST_HASH_FILE="$RUN_DIR/pinky-direct-watch.last-hash"
MAX_RUNS="${PINKY_MAX_RUNS:-1}"
SLEEP_SECONDS="${PINKY_SLEEP_SECONDS:-1}"
mkdir -p "$RUN_DIR"
runs=0
printf "PINKY-DIRECT-WATCH state=watching max_runs=%s
" "$MAX_RUNS"
while [[ "$runs" -lt "$MAX_RUNS" ]]; do
  if "$ROOT_DIR/bin/pinky-direct-once"; then
    candidate=""
    [[ -f "$RUN_DIR/pinky-command.candidate" ]] && candidate="$(cat "$RUN_DIR/pinky-command.candidate")"
    hash="$(printf "%s" "$candidate" | shasum -a 256 | awk "{print \$1}")"
    last_hash=""
    [[ -f "$LAST_HASH_FILE" ]] && last_hash="$(cat "$LAST_HASH_FILE")"
    if [[ -n "$candidate" && "$hash" != "$last_hash" ]]; then
      printf "%s
" "$hash" > "$LAST_HASH_FILE"
      runs=$((runs + 1))
    fi
  fi
  sleep "$SLEEP_SECONDS"
done
printf "PINKY-DIRECT-WATCH state=done runs=%s
" "$runs"
