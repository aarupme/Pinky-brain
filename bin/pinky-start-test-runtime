#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

RUN_DIR="$ROOT_DIR/.run"
mkdir -p "$RUN_DIR"

pkill -f 'bin/pinky-cockpit-watch' 2>/dev/null || true
sleep 1

rm -f "$RUN_DIR/pinky-command.last-hash" \
      "$RUN_DIR/pinky-command.candidate" \
      "$RUN_DIR/pinky-visible.txt" \
      "$RUN_DIR/pinky-cockpit-watch.last-attempt-hash" \
      "$RUN_DIR/pinky-cockpit-watch.last-success-hash" \
      "$RUN_DIR/pinky-transport-complete" \
      "$RUN_DIR/pinky-test-runtime.log" \
      "$RUN_DIR/pinky-test-runtime.pid"

printf 'PINKY starting test runtime. Auto-Narf disabled.\n'

PINKY_ALLOW_NARF=0 PINKY_SLEEP_SECONDS=1 "$ROOT_DIR/bin/pinky-cockpit-watch" \
  > "$RUN_DIR/pinky-test-runtime.log" 2>&1 &
echo $! > "$RUN_DIR/pinky-test-runtime.pid"

printf 'PINKY test runtime pid=%s log=%s\n' "$(cat "$RUN_DIR/pinky-test-runtime.pid")" "$RUN_DIR/pinky-test-runtime.log"
printf 'PINKY test runtime started\n'
