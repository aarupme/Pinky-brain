#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUN_DIR="$ROOT_DIR/.run"
LOG_DIR="$ROOT_DIR/logs"
STOP_FILE="$RUN_DIR/pinky-loop.stop"
PID_FILE="$RUN_DIR/pinky-loop.pid"
LOG_FILE="$LOG_DIR/pinky-loop.log"
LAST_HASH_FILE="$RUN_DIR/pinky-loop.last-hash"
LAST_SEND_FILE="$RUN_DIR/pinky-loop.last-send"
COMMAND_DUPLICATE_HASH_FILE="$RUN_DIR/pinky-command.duplicate-last-hash"

mkdir -p "$RUN_DIR" "$LOG_DIR"

usage() {
  cat <<'EOF'
Usage:
  pinky-loop start
  pinky-loop stop
  pinky-loop status
  pinky-loop once
EOF
}

cooldown_ready() {
  local now
  local last
  now="$(date +%s)"
  if [[ ! -f "$LAST_SEND_FILE" ]]; then
    return 0
  fi
  last="$(cat "$LAST_SEND_FILE" || echo 0)"
  [[ $((now - last)) -ge 8 ]]
}

mark_sent() {
  date +%s > "$LAST_SEND_FILE"
}

loop_once() {
  if [[ -f "$STOP_FILE" ]]; then
    echo "loop=stopped"
    return 0
  fi

  if "$ROOT_DIR/bin/pinky-command-detect" >/dev/null 2>&1; then
    set +e
    extract_output="$("$ROOT_DIR/bin/pinky-command-extract" 2>&1)"
    extract_exit="$?"
    set -e
    if [[ "$extract_exit" -eq 0 ]]; then
      "$ROOT_DIR/bin/pinky-command-run" >> "$LOG_FILE" 2>&1 || true
      "$ROOT_DIR/bin/pinky-set-state" watching >/dev/null 2>&1 || true
      echo "loop=command-checked"
      return 0
    fi
    if [[ "$extract_exit" -eq 4 ]]; then
      reject_reason="$(printf "%s\\n" "$extract_output" | awk -F= '/^reason=/{print $2; exit}')"
      reject_source="$(printf "%s\\n" "$extract_output" | awk -F= '/^source=/{print $2; exit}')"
      [[ -n "${reject_reason:-}" ]] || reject_reason="unknown"
      [[ -n "${reject_source:-}" ]] || reject_source="unknown"
      "$ROOT_DIR/bin/pinky-set-state" watching >/dev/null 2>&1 || true
      printf "%s command=rejected source=%s reason=%s\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$reject_source" "$reject_reason" >> "$LOG_FILE"
      echo "loop=command-rejected"
      echo "source=$reject_source"
      echo "reason=$reject_reason"
      return 0
    fi
    if [[ "$extract_exit" -eq 3 ]]; then
      duplicate_hash="$(printf "%s\\n" "$extract_output" | awk -F= '/^candidate_hash=/{print $2; exit}')"
      [[ -n "${duplicate_hash:-}" ]] || duplicate_hash="duplicate"
      last_duplicate_hash=""
      [[ -f "$COMMAND_DUPLICATE_HASH_FILE" ]] && last_duplicate_hash="$(cat "$COMMAND_DUPLICATE_HASH_FILE" || true)"
      "$ROOT_DIR/bin/pinky-set-state" watching >/dev/null 2>&1 || true
      printf "%s command=duplicate candidate_hash=%s\\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$duplicate_hash" >> "$LOG_FILE"
      if [[ "$duplicate_hash" != "$last_duplicate_hash" ]]; then
        printf "%s" "$duplicate_hash" > "$COMMAND_DUPLICATE_HASH_FILE"
        echo "loop=command-duplicate-silent"
      else
        echo "loop=command-duplicate-suppressed"
      fi
      sleep 1
      "$ROOT_DIR/bin/pinky-set-state" watching >/dev/null 2>&1 || true
      return 0
    fi
  fi

  tmp_output="$(mktemp)"
  "$ROOT_DIR/bin/pinky-watch-once" > "$tmp_output" 2>&1 &
  watch_pid="$!"

  elapsed=0
  while kill -0 "$watch_pid" >/dev/null 2>&1; do
    if [[ "$elapsed" -ge 8 ]]; then
      kill "$watch_pid" >/dev/null 2>&1 || true
      sleep 0.2
      if kill -0 "$watch_pid" >/dev/null 2>&1; then
        kill -9 "$watch_pid" >/dev/null 2>&1 || true
      fi
      printf "%s signal=timeout\n" "$(date '+%Y-%m-%d %H:%M:%S')" >> "$LOG_FILE"
      rm -f "$tmp_output"
      echo "loop=watch-timeout"
      return 0
    fi
    sleep 1
    elapsed=$((elapsed + 1))
  done

  current_signal_state=""
  [[ -f "$RUN_DIR/pinky-signal.state" ]] && current_signal_state="$(cat "$RUN_DIR/pinky-signal.state" || true)"
  if [[ "$current_signal_state" != "brain" ]]; then
    "$ROOT_DIR/bin/pinky-set-state" reading >/dev/null 2>&1 || true
  fi
  signal_output="$(cat "$tmp_output" || true)"
  rm -f "$tmp_output"
  signal="$(printf "%s\n" "$signal_output" | awk -F= '/^signal=/{print $2; exit}')"
  signal_hash="$(printf "%s\n" "$signal_output" | awk -F= '/^signal_hash=/{print $2; exit}')"
  [[ -n "${signal_hash:-}" ]] || signal_hash="none"

  case "$signal" in
    none|pinky|brain|stop)
      ;;
    *)
      echo "pinky-loop error: unknown signal: ${signal:-empty}" >&2
      return 1
      ;;
  esac

  printf "%s signal=%s\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$signal" >> "$LOG_FILE"

  case "$signal" in
    brain)
      "$ROOT_DIR/bin/pinky-set-state" brain "${signal_hash:-brain}" >/dev/null 2>&1 || true
      echo "loop=brain-needed"
      ;;
    stop)
      touch "$STOP_FILE"
      "$ROOT_DIR/bin/pinky-set-state" stopped >/dev/null
      echo "loop=hard-stop"
      ;;
    pinky)
      hash="$signal_hash"
      last_hash=""
      [[ -f "$LAST_HASH_FILE" ]] && last_hash="$(cat "$LAST_HASH_FILE" || true)"

      if [[ "$hash" == "$last_hash" ]]; then
        "$ROOT_DIR/bin/pinky-set-state" watching >/dev/null 2>&1 || true
        printf "%s autosend=skipped reason=same-hash hash=%s\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$hash" >> "$LOG_FILE"
        sleep 1
        "$ROOT_DIR/bin/pinky-set-state" watching >/dev/null 2>&1 || true
        echo "loop=pinky-skipped-same-message"
        return 0
      fi

      if ! cooldown_ready; then
        printf "%s autosend=skipped reason=cooldown hash=%s\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$hash" >> "$LOG_FILE"
        echo "loop=pinky-skipped-cooldown"
        return 0
      fi

      "$ROOT_DIR/bin/pinky-send" --text "Narf!"
      printf "%s\n" "$hash" > "$LAST_HASH_FILE"
      mark_sent
      printf "%s autosend=Narf hash=%s\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$hash" >> "$LOG_FILE"
      echo "loop=pinky-autosent-narf"
      ;;
    none)
      "$ROOT_DIR/bin/pinky-set-state" watching >/dev/null 2>&1 || true
      echo "loop=watching"
      ;;
  esac
}

start_loop() {
  "$ROOT_DIR/bin/pinky-loop" stop >/dev/null 2>&1 || true
  rm -f "$STOP_FILE"

  (
    while [[ ! -f "$STOP_FILE" ]]; do
      "$ROOT_DIR/bin/pinky-loop" once >> "$LOG_FILE" 2>&1 || true
      sleep 2
    done
  ) &
  pid="$!"
  printf "%s\n" "$pid" > "$PID_FILE"

  echo "Pinky loop started"
  echo "pid=$pid"
  echo "log=$LOG_FILE"
}

kill_pid() {
  local pid="$1"
  [[ -n "$pid" ]] || return 0
  [[ "$pid" == "$$" ]] && return 0

  if kill -0 "$pid" >/dev/null 2>&1; then
    kill "$pid" >/dev/null 2>&1 || true
    sleep 0.2
    if kill -0 "$pid" >/dev/null 2>&1; then
      kill -9 "$pid" >/dev/null 2>&1 || true
    fi
  fi
}

stop_loop() {
  touch "$STOP_FILE"

  if [[ -f "$PID_FILE" ]]; then
    kill_pid "$(cat "$PID_FILE" || true)"
    rm -f "$PID_FILE"
  fi

  while IFS= read -r pid; do
    kill_pid "$pid"
  done < <(
    ps -axo pid=,command= |
      awk -v root="$ROOT_DIR" '
        $0 ~ root "/bin/pinky-loop once" {print $1}
        $0 ~ root "/bin/pinky-watch-once" {print $1}
        $0 ~ root "/bin/pinky-detect-signal" {print $1}
        $0 ~ root "/bin/pinky-read-visible" {print $1}
      '
  )

  echo "Pinky loop stopped"
}

status_loop() {
  tracked_pid="none"

  if [[ -f "$PID_FILE" ]]; then
    tracked_pid="$(cat "$PID_FILE" || true)"
    if [[ -z "${tracked_pid:-}" ]] || ! kill -0 "$tracked_pid" >/dev/null 2>&1; then
      rm -f "$PID_FILE"
      tracked_pid="none"
    fi
  fi

  echo "--- loop pid ---"
  echo "$tracked_pid"

  echo "--- stop file ---"
  if [[ -f "$STOP_FILE" ]]; then
    echo "present"
  else
    echo "absent"
  fi

  echo "--- last hash ---"
  if [[ -f "$LAST_HASH_FILE" ]]; then
    cat "$LAST_HASH_FILE"
  else
    echo "none"
  fi

  echo "--- active loop processes ---"
  ps -axo pid,command |
    grep -F "$ROOT_DIR/bin/pinky-loop" |
    grep -v grep |
    grep -v "pinky-loop status" ||
    echo "none"
}

case "${1:-}" in
  start)
    start_loop
    ;;
  stop)
    stop_loop
    ;;
  status)
    status_loop
    ;;
  once)
    loop_once
    ;;
  help|--help|-h)
    usage
    ;;
  "")
    usage
    exit 1
    ;;
  *)
    echo "pinky-loop error: unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
