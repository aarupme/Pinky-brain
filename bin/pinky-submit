#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
RUN_DIR="$ROOT_DIR/.run"
COMMAND_FILE="$RUN_DIR/pinky-code-editor-command.txt"
CANDIDATE_FILE="$RUN_DIR/pinky-command.candidate"
TRANSPORT_FILE="$RUN_DIR/pinky-transport.input"
mkdir -p "$RUN_DIR"

if [[ -s "$COMMAND_FILE" || -s "$CANDIDATE_FILE" || -s "$TRANSPORT_FILE" ]]; then
  echo "PINKY submit refused: command already pending or running" >&2
  echo "command_file_bytes=$(wc -c < "$COMMAND_FILE" 2>/dev/null || echo 0)" >&2
  echo "candidate_file=$(if [[ -s "$CANDIDATE_FILE" ]]; then echo present; else echo none; fi)" >&2
  echo "transport_file=$(if [[ -s "$TRANSPORT_FILE" ]]; then echo present; else echo none; fi)" >&2
  exit 75
fi

tmp="$COMMAND_FILE.tmp.$$"
cat > "$tmp"
if ! grep -q "^PINKY-BASH-START$" "$tmp" || ! grep -q "^PINKY-BASH-END$" "$tmp"; then
  rm -f "$tmp"
  echo "PINKY submit refused: missing v2 envelope" >&2
  exit 64
fi
mv "$tmp" "$COMMAND_FILE"
echo "PINKY submit wrote $COMMAND_FILE"
