#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
COMMAND_FILE="$ROOT_DIR/.run/pinky-courier.command"
[[ $# -ge 1 ]] || { printf "usage: pinky-do <command>\n" >&2; exit 2; }
mkdir -p "$ROOT_DIR/.run"
printf "%s\n" "$*" > "$COMMAND_FILE"
"$ROOT_DIR/bin/pinky-courier"
