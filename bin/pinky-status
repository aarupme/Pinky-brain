#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

print_transport_completion_summary() {
  local completion_sentinel="$ROOT_DIR/.run/pinky-transport-complete"
  local latest_transport_log latest_transport_base latest_transport_time latest_transport_hash latest_transport_exit
  latest_transport_log="$(ls -t "$ROOT_DIR"/logs/transport-runs/*.log 2>/dev/null | head -1 || true)"

  if [[ -n "${latest_transport_log:-}" ]]; then
    latest_transport_base="$(basename "$latest_transport_log")"
    latest_transport_time="${latest_transport_base:0:8} ${latest_transport_base:9:2}:${latest_transport_base:11:2}:${latest_transport_base:13:2}"
    latest_transport_hash="$(printf "%s" "$latest_transport_base" | sed -E 's/^[0-9]{8}-[0-9]{6}-([^.]+)\.log$/\1/')"
    latest_transport_exit="unknown"

    if [[ -s "$completion_sentinel" ]]; then
      sentinel_hash="$(grep '^hash=' "$completion_sentinel" 2>/dev/null | tail -1 | cut -d= -f2- || true)"
      sentinel_exit="$(grep '^exit_code=' "$completion_sentinel" 2>/dev/null | tail -1 | cut -d= -f2- || true)"
      if [[ "$sentinel_hash" == "$latest_transport_hash" && -n "$sentinel_exit" ]]; then
        latest_transport_exit="$sentinel_exit"
      fi
    fi

    if [[ "$latest_transport_exit" == "unknown" && -n "$latest_transport_hash" ]]; then
      latest_transport_exit="$(grep -R "hash=$latest_transport_hash" "$ROOT_DIR/logs" 2>/dev/null | grep "PINKY transport complete exit=" | tail -1 | sed -E 's/.*exit=([0-9]+).*/\1/' || true)"
      [[ -n "$latest_transport_exit" ]] || latest_transport_exit="unknown"
    fi

    echo "last_transport=time=$latest_transport_time exit_code=$latest_transport_exit log=$latest_transport_log hash=$latest_transport_hash"
  fi

  if [[ -s "$completion_sentinel" ]]; then
    sentinel_hash="$(grep '^hash=' "$completion_sentinel" 2>/dev/null | tail -1 | cut -d= -f2- || true)"
    sentinel_exit="$(grep '^exit_code=' "$completion_sentinel" 2>/dev/null | tail -1 | cut -d= -f2- || true)"
    sentinel_time="$(grep '^completed_at=' "$completion_sentinel" 2>/dev/null | tail -1 | cut -d= -f2- || true)"
    echo "last_completion=time=${sentinel_time:-unknown} exit_code=${sentinel_exit:-unknown} hash=${sentinel_hash:-unknown} file=$completion_sentinel"
  fi
}

RUN_DIR="$ROOT_DIR/.run"
LOG_DIR="$ROOT_DIR/logs"
LOOP_PID="$RUN_DIR/pinky-loop.pid"
LOOP_STOP="$RUN_DIR/pinky-loop.stop"
LOOP_LAST_HASH="$RUN_DIR/pinky-loop.last-hash"
LOOP_LAST_SEND="$RUN_DIR/pinky-loop.last-send"
BEACON_PID="$RUN_DIR/pinky-beacon.pid"
WATCHER_PID="$RUN_DIR/pinky-cockpit-watch.pid"
COMMAND_CANDIDATE="$RUN_DIR/pinky-command.candidate"

read_oneline() {
  local path="$1"
  if [[ -s "$path" ]]; then
    head -n 1 "$path" | tr '\n' ' '
    printf '\n'
  else
    printf 'none\n'
  fi
}

pid_status() {
  local label="$1"
  local pid_file="$2"
  local pid="none"
  local state="stopped"
  if [[ -s "$pid_file" ]]; then
    pid="$(cat "$pid_file" 2>/dev/null || true)"
    if [[ -n "$pid" ]] && kill -0 "$pid" >/dev/null 2>&1; then
      state="running"
    else
      state="stale-pid"
    fi
  fi
  printf '%s=%s pid=%s\n' "$label" "$state" "$pid"
}

log_tail() {
  local label="$1"
  local path="$2"
  printf '%s\n' "--- $label ---"
  if [[ -s "$path" ]]; then
    tail -n 4 "$path"
  else
    printf 'none\n'
  fi
}

"$ROOT_DIR/bin/pinky-cockpit"
printf '\n'
printf '== Pinky Status ==\n'
printf 'root=%s\n\n' "$ROOT_DIR"

printf '%s\n' '--- git ---'
if [[ -n "$(git -C "$ROOT_DIR" status --short 2>/dev/null)" ]]; then
  printf 'git=dirty\n'
  git -C "$ROOT_DIR" status --short | sed -n '1,40p'
else
  printf 'git=clean\n'
fi

printf '\n%s\n' '--- protocol ---'
printf 'startup-chat=compact\n'
printf 'protocol-source=terminal:pinky-protocol\n'
printf 'start-prompt=prompts/runtime-start.txt\n'

printf '\n%s\n' '--- runtime ---'
printf 'ready means watcher=running and candidate=none\n'
pid_status "watcher" "$WATCHER_PID"
pid_status "loop" "$LOOP_PID"
pid_status "beacon" "$BEACON_PID"
if [[ -e "$LOOP_STOP" ]]; then
  printf 'loop-stop=present\n'
else
  printf 'loop-stop=absent\n\n'
fi

printf '%s\n' '--- signal ---'
printf 'last-hash='
read_oneline "$LOOP_LAST_HASH"
printf 'last-send='
read_oneline "$LOOP_LAST_SEND"

printf '\n%s\n' '--- command ---'
if [[ -s "$COMMAND_CANDIDATE" ]]; then
  printf 'candidate=present\n  '
  head -n 1 "$COMMAND_CANDIDATE"
  printf '\n'
  "$ROOT_DIR/bin/pinky-command-dry-run" | sed -n '1,40p'
else
  printf 'candidate=none\ndry-run=none\n'
fi

printf '\n%s\n' '--- recent logs ---'
log_tail "pinky-loop.log" "$LOG_DIR/pinky-loop.log"
log_tail "pinky-signal.log" "$LOG_DIR/pinky-signal.log"
log_tail "pinky-command-run.log" "$LOG_DIR/pinky-command-run.log"

printf '\n--- transport completion ---\n'
print_transport_completion_summary

printf '\n--- report ---\n'
"$ROOT_DIR/bin/pinky-cockpit"
