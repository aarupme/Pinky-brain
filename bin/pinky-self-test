#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

printf "== Pinky Self Test ==\n"
printf "root=%s\n\n" "$ROOT_DIR"

printf "%s\n" "--- status ---"
./bin/pinky-status

printf "\n%s\n" "--- signal fixtures ---"
tests/run-detect-signal-fixtures

printf "\n%s\n" "--- command fixtures ---"
tests/run-command-extract-fixtures

printf "\n%s\n" "--- result ---"
printf "self-test=pass\n"
