#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUN_DIR="$ROOT_DIR/.run"
TMP_FILE="$(mktemp)"
CANDIDATE_FILE="$RUN_DIR/pinky-command.candidate"
LAST_HASH_FILE="$RUN_DIR/pinky-command.last-hash"
mkdir -p "$RUN_DIR"
trap 'rm -f "$TMP_FILE"' EXIT
READ_VISIBLE="${PINKY_READ_VISIBLE:-$ROOT_DIR/bin/pinky-read-visible}"
"$READ_VISIBLE" > "$TMP_FILE" 2>&1 || {
  echo "pinky-command-extract error: failed to read visible ChatGPT text" >&2
  exit 1
}
rm -f "$CANDIDATE_FILE"

code_command="$(python3 - "$TMP_FILE" <<'PY'
import sys

path = sys.argv[1]
text = open(path, "r", encoding="utf-8", errors="replace").read()
marker = "PINKY-CODE-RUN"
fence = chr(96) * 3
idx = text.rfind(marker)
marker_seen = idx >= 0
if idx >= 0:
    tail = text[idx + len(marker):]
    start = tail.find(fence)
    if start >= 0:
        after = tail[start + len(fence):]
        newline = after.find("\n")
        if newline >= 0:
            body_start = newline + 1
            end = after.find(fence, body_start)
            if end >= 0:
                payload = after[body_start:end].strip()
                if payload:
                    print(payload)
                    raise SystemExit(0)
if marker_seen:
    print("__PINKY_CODE_MARKER_INVALID__")
raise SystemExit(2)
PY
)" || true

if [[ "${code_command:-}" == "__PINKY_CODE_MARKER_INVALID__" ]]; then
  echo "pinky_command=rejected"
  echo "source=code-block"
  echo "reason=code-marker-without-valid-block"
  rm -f "$CANDIDATE_FILE"
  exit 4
fi

if [[ -n "${code_command:-}" ]]; then
  printf "%s\n" "$code_command" | "$ROOT_DIR/bin/pinky-command-normalize" > "$CANDIDATE_FILE"
else
  awk 'index($0, "🧰 PINKY-RUN") { armed=1; command=""; next } armed && /^[[:space:]]*cd[[:space:]]+~\/Desktop\/pinky-brain[[:space:]]+&&/ && $0 !~ /pinky-command-extract/ { command=$0; next } armed && index($0, "🧰 PINKY-READY") && command != "" { last_command=command; found=1; armed=0; command=""; next } END { if (found) print last_command; else exit 2 }' "$TMP_FILE" | "$ROOT_DIR/bin/pinky-command-normalize" > "$CANDIDATE_FILE" || true
fi

if [[ -s "$CANDIDATE_FILE" ]]; then
  command_text="$(cat "$CANDIDATE_FILE")"
  command_hash="$(printf "%s" "$command_text" | shasum -a 256 | awk '{print $1}')"
  last_hash=""
  if [[ -s "$LAST_HASH_FILE" ]]; then
    last_hash="$(cat "$LAST_HASH_FILE")"
  fi
  if [[ -n "$last_hash" && "$command_hash" == "$last_hash" ]]; then
    rm -f "$CANDIDATE_FILE"
    echo "pinky_command=duplicate"
    echo "candidate_hash=$command_hash"
    exit 3
  fi
  echo "pinky_command=present"
  if [[ -n "${code_command:-}" ]]; then
    echo "source=code-block"
  else
    echo "source=toolbox"
  fi
  echo "candidate_file=$CANDIDATE_FILE"
else
  rm -f "$CANDIDATE_FILE"
  echo "pinky_command=none"
  exit 2
fi
