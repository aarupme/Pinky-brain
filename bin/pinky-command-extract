#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUN_DIR="$ROOT_DIR/.run"
TMP_FILE="$(mktemp)"
CANDIDATE_FILE="$RUN_DIR/pinky-command.candidate"
CODE_EDITOR_FILE="$RUN_DIR/pinky-code-editor-command.txt"
LAST_HASH_FILE="$RUN_DIR/pinky-command.last-hash"
SEEN_HASHES_FILE="$RUN_DIR/pinky-command.seen-hashes"
mkdir -p "$RUN_DIR"
trap 'rm -f "$TMP_FILE"' EXIT
READ_VISIBLE="${PINKY_READ_VISIBLE:-$ROOT_DIR/bin/pinky-read-visible}"
if [[ -s "$CODE_EDITOR_FILE" ]]; then
  cat "$CODE_EDITOR_FILE" > "$TMP_FILE"
else
  "$READ_VISIBLE" > "$TMP_FILE" 2>&1 || {
    echo "pinky-command-extract error: failed to read visible ChatGPT text" >&2
    exit 1
  }
fi
rm -f "$CANDIDATE_FILE"

envelope_command="$(python3 - "$TMP_FILE" <<'PY'
import sys

path = sys.argv[1]
text = open(path, "r", encoding="utf-8", errors="replace").read()
start_marker = "PINKY-BASH-START"
end_marker = "PINKY-BASH-END"
start = text.rfind(start_marker)
if start < 0:
    raise SystemExit(2)
after = text[start + len(start_marker):]
end = after.find(end_marker)
if end < 0:
    print("__PINKY_ENVELOPE_INCOMPLETE__")
    raise SystemExit(0)
payload = after[:end].strip()
if not payload:
    print("__PINKY_ENVELOPE_EMPTY__")
    raise SystemExit(0)
if "PINKY-BASH-START" in payload or "PINKY-BASH-END" in payload:
    print("__PINKY_ENVELOPE_NESTED__")
    raise SystemExit(0)
print(payload)
PY
)" || true

case "${envelope_command:-}" in
  "__PINKY_ENVELOPE_INCOMPLETE__"|"__PINKY_ENVELOPE_EMPTY__"|"__PINKY_ENVELOPE_NESTED__")
    echo "pinky_command=rejected"
    echo "source=envelope"
    echo "reason=${envelope_command#__PINKY_}"
    rm -f "$CANDIDATE_FILE"
    exit 4
    ;;
esac

if [[ -n "${envelope_command:-}" ]]; then
  printf "%s\n" "$envelope_command" | "$ROOT_DIR/bin/pinky-command-normalize" > "$CANDIDATE_FILE"
else
  rm -f "$CANDIDATE_FILE"
  echo "pinky_command=none"
  exit 2
fi

if [[ -s "$CANDIDATE_FILE" ]]; then
  command_text="$(cat "$CANDIDATE_FILE")"
  command_hash="$(printf "%s" "$command_text" | shasum -a 256 | awk '{print $1}')"
  last_hash=""
  if [[ -s "$LAST_HASH_FILE" ]]; then
    last_hash="$(cat "$LAST_HASH_FILE")"
  fi
  if [[ -n "$last_hash" && "$command_hash" == "$last_hash" ]]; then
    rm -f "$CANDIDATE_FILE"
    echo "pinky_command=duplicate"
    echo "candidate_hash=$command_hash"
    exit 3
  fi
  if [[ -s "$SEEN_HASHES_FILE" ]] && grep -qx "$command_hash" "$SEEN_HASHES_FILE"; then
    rm -f "$CANDIDATE_FILE"
    echo "pinky_command=duplicate"
    echo "candidate_hash=$command_hash"
    exit 3
  fi
  echo "pinky_command=present"
  if [[ -n "${code_command:-}" ]]; then
    echo "source=envelope"
  else
    echo "source=envelope"
  fi
  echo "candidate_file=$CANDIDATE_FILE"
else
  rm -f "$CANDIDATE_FILE"
  echo "pinky_command=none"
  exit 2
fi
