#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"
RUN_DIR="$ROOT_DIR/.run"
mkdir -p "$RUN_DIR" logs

INBOX="$RUN_DIR/pinky-command-inbox.sh"
LAST="$RUN_DIR/pinky-file-watch.last"
OUT="$RUN_DIR/pinky-file-watch.out"
INTERVAL="${PINKY_FILE_SLEEP_SECONDS:-1}"

touch "$INBOX"
printf "PINKY file watcher started inbox=%s\n" "$INBOX"

while true; do
  osascript -e 'tell application "Visual Studio Code" to activate' -e 'tell application "System Events" to keystroke "s" using command down' >/dev/null 2>&1 || true
  sleep 0.2
  if [[ -s "$INBOX" ]]; then
    first="$(grep -v "^[[:space:]]*$" "$INBOX" | head -1 || true)"
    if [[ "$first" == "# pinky" ]]; then
      hash="$(shasum -a 256 "$INBOX" | awk '{print $1}')"
      last="$(cat "$LAST" 2>/dev/null || true)"
      if [[ "$hash" != "$last" ]]; then
        printf "%s" "$hash" > "$LAST"
        id="$(date +%Y%m%d%H%M%S)-$$"
        done_token="PINKY_FILE_DONE:$id:"
        wrap="$RUN_DIR/pinky-file-wrapper.sh"
        printf "\n=== PINKY FILE PICKED hash=%s id=%s ===\n" "$hash" "$id"
        sed -n "1,220p" "$INBOX"
        printf "%s\n" "#!/usr/bin/env bash" "set +e" > "$wrap"
        grep -v "^[[:space:]]*# pinky[[:space:]]*$" "$INBOX" >> "$wrap"
        printf "%s\n" "rc=\$?" "printf \"\\n%s%s\\n\" \"$done_token\" \"\$rc\"" "exit \"\$rc\"" >> "$wrap"
        chmod +x "$wrap"
        set +e
        bash "$wrap" 2>&1 | tee "$OUT"
        rc="${PIPESTATUS[0]}"
        set -e
        if grep -q "$done_token" "$OUT"; then
          printf "PINKY_FILE completion_seen=yes exit=%s id=%s\n" "$rc" "$id"
          "$ROOT_DIR/bin/pinky-send" --text "Narf!" || true
        else
          printf "PINKY_FILE completion_seen=no exit=%s id=%s\n" "$rc" "$id" >&2
          "$ROOT_DIR/bin/pinky-send" --text "NARF failed=true reason=no-completion" || true
        fi
      fi
    fi
  fi
  sleep "$INTERVAL"
done
