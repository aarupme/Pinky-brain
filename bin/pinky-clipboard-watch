#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUN_DIR="$ROOT_DIR/.run"
LAST_HASH_FILE="$RUN_DIR/pinky-clipboard-watch.last-hash"
MAX_RUNS="${PINKY_MAX_RUNS:-1}"
SLEEP_SECONDS="${PINKY_SLEEP_SECONDS:-1}"
mkdir -p "$RUN_DIR"
runs=0
printf "PINKY-CLIPBOARD-WATCH state=watching max_runs=%s\n" "$MAX_RUNS"
while [[ "$runs" -lt "$MAX_RUNS" ]]; do
  cmd="$(pbpaste || true)"
  if [[ "$cmd" == cd\ ~/Desktop/pinky-brain* && "$cmd" == *"# pinky"* ]]; then
    clean_cmd="${cmd%# pinky}"
    hash="$(printf "%s" "$clean_cmd" | shasum -a 256 | awk "{print \$1}")"
    last_hash=""
    [[ -f "$LAST_HASH_FILE" ]] && last_hash="$(cat "$LAST_HASH_FILE")"
    if [[ "$hash" != "$last_hash" ]]; then
      printf "%s\n" "$hash" > "$LAST_HASH_FILE"
      printf "%s\n" "$clean_cmd" > "$RUN_DIR/pinky-transport.input"
      "$ROOT_DIR/bin/pinky-transport-once"
      runs=$((runs + 1))
    fi
  fi
  sleep "$SLEEP_SECONDS"
done
printf "PINKY-CLIPBOARD-WATCH state=done runs=%s\n" "$runs"
