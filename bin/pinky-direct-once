#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUN_DIR="$ROOT_DIR/.run"
mkdir -p "$RUN_DIR"
rm -f "$RUN_DIR/pinky-command.candidate" "$RUN_DIR/pinky-transport.input"
"$ROOT_DIR/bin/pinky-command-extract"
cp "$RUN_DIR/pinky-command.candidate" "$RUN_DIR/pinky-transport.input"
"$ROOT_DIR/bin/pinky-transport-once"
