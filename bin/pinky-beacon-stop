#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PID_FILE="$ROOT_DIR/.run/pinky-beacon.pid"
SELF_PID="$$"

kill_pid() {
  local pid="$1"
  [[ -n "$pid" ]] || return 0
  [[ "$pid" == "$SELF_PID" ]] && return 0

  if kill -0 "$pid" >/dev/null 2>&1; then
    kill "$pid" >/dev/null 2>&1 || true
    sleep 0.2
    if kill -0 "$pid" >/dev/null 2>&1; then
      kill -9 "$pid" >/dev/null 2>&1 || true
    fi
  fi
}

if [[ -f "$PID_FILE" ]]; then
  kill_pid "$(cat "$PID_FILE" || true)"
  rm -f "$PID_FILE"
fi

while IFS= read -r pid; do
  kill_pid "$pid"
done < <(
  ps -axo pid=,command= |
    awk -v root="$ROOT_DIR" '
      $0 ~ root "/bin/pinky-beacon$" {print $1}
      $0 ~ root "/bin/pinky-beacon " {print $1}
    '
)

echo "Pinky beacon stopped"
