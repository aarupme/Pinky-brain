#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TMP_FILE="$(mktemp)"
trap 'rm -f "$TMP_FILE"' EXIT
READ_VISIBLE="${PINKY_READ_VISIBLE:-$ROOT_DIR/bin/pinky-read-visible}"
"$READ_VISIBLE" > "$TMP_FILE" 2>&1 || {
  echo "pinky-command-detect error: failed to read visible ChatGPT text" >&2
  exit 1
}
if grep -Fq "🧰 PINKY-RUN" "$TMP_FILE" && grep -Fq "🧰 PINKY-READY" "$TMP_FILE"; then
  echo "pinky_runnable=present"
  exit 0
else
  echo "pinky_runnable=none"
  exit 2
fi
