#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"
RUN_DIR="$ROOT_DIR/.run"
mkdir -p "$RUN_DIR" logs

LAST="$RUN_DIR/pinky-min-watch.last"
INTERVAL="${PINKY_MIN_SLEEP_SECONDS:-1}"
printf "PINKY_MIN watch started. Syntax: PINKY: <single-line bash>\n"

while true; do
  "$ROOT_DIR/bin/pinky-read-visible" > "$RUN_DIR/pinky-min-watch-visible.txt" 2>&1 || true
  cmd="$(awk '/^PINKY:[[:space:]]*/ {sub(/^PINKY:[[:space:]]*/, "", $0); c=$0} END{print c}' "$RUN_DIR/pinky-min-watch-visible.txt")"
  if [[ -n "$cmd" ]]; then
    hash="$(printf "%s" "$cmd" | shasum -a 256 | awk '{print $1}')"
    last="$(cat "$LAST" 2>/dev/null || true)"
    if [[ "$hash" != "$last" ]]; then
      printf "%s" "$hash" > "$LAST"
      printf "PINKY_MIN watch picked hash=%s\n" "$hash"
      "$ROOT_DIR/bin/pinky-min-once" || true
    fi
  fi
  sleep "$INTERVAL"
done
