#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
START_PROMPT="$ROOT_DIR/prompts/runtime-start.txt"
STOP_PROMPT="$ROOT_DIR/prompts/runtime-stop.txt"
LOG_DIR="$ROOT_DIR/logs"
SEND_LOG="$LOG_DIR/pinky-send.log"
mkdir -p "$LOG_DIR"

usage() {
  cat <<'EOF'
Usage:
  pinky-send --text "message"
  pinky-send --file path/to/file.txt
  pinky-send --start
  pinky-send --stop
  pinky-send --help
EOF
}

fail() {
  echo "pinky-send error: $1" >&2
  exit 1
}

send_text() {
  local message="$1"

  [[ -n "$message" ]] || fail "message is empty"

  printf "%s send=attempt bytes=%s\\n" "$(date '+%Y-%m-%d %H:%M:%S')" "${#message}" >> "$SEND_LOG"

  set +e
  osascript - "$message" <<'APPLESCRIPT'
on run argv
  set messageText to item 1 of argv

  tell application "ChatGPT"
    activate
  end tell

  tell application "System Events"
    set chatGPTReady to false
    repeat 20 times
      delay 0.1
      if exists process "ChatGPT" then
        if frontmost of process "ChatGPT" is true then
          set chatGPTReady to true
          exit repeat
        end if
      end if
    end repeat
  end tell

  if chatGPTReady is false then
    error "ChatGPT did not become frontmost; refusing to paste callback"
  end if

  set oldClipboard to the clipboard
  set the clipboard to messageText

  tell application "System Events"
    keystroke "v" using command down
    delay 0.2
    key code 36
  end tell

  delay 0.2
  set the clipboard to oldClipboard
end run
APPLESCRIPT
  local send_exit="$?"
  set -e
  if [[ "$send_exit" -eq 0 ]]; then
    printf "%s send=success\\n" "$(date '+%Y-%m-%d %H:%M:%S')" >> "$SEND_LOG"
  else
    printf "%s send=failed exit_code=%s\\n" "$(date '+%Y-%m-%d %H:%M:%S')" "$send_exit" >> "$SEND_LOG"
    return "$send_exit"
  fi
}

send_file() {
  local file_path="$1"

  [[ -n "$file_path" ]] || fail "file path is empty"
  [[ -f "$file_path" ]] || fail "file does not exist: $file_path"

  local message
  message="$(cat "$file_path")"
  send_text "$message"
}

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

case "${1:-}" in
  --text)
    [[ $# -eq 2 ]] || fail "--text requires exactly one message argument"
    send_text "$2"
    ;;
  --file)
    [[ $# -eq 2 ]] || fail "--file requires exactly one path argument"
    send_file "$2"
    ;;
  --start)
    [[ $# -eq 1 ]] || fail "--start does not accept extra arguments"
    send_file "$START_PROMPT"
    ;;
  --stop)
    [[ $# -eq 1 ]] || fail "--stop does not accept extra arguments"
    send_file "$STOP_PROMPT"
    ;;
  --help|-h)
    usage
    ;;
  *)
    fail "unknown argument: $1"
    ;;
esac
