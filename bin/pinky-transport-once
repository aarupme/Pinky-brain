#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
RUN_DIR="$ROOT_DIR/.run"
LOG_DIR="$ROOT_DIR/logs/transport-runs"
mkdir -p "$RUN_DIR" "$LOG_DIR"
INPUT_FILE="${1:-$RUN_DIR/pinky-transport.input}"
[[ -s "$INPUT_FILE" ]] || { printf "NARF failed=true reason=missing-input\n"; exit 2; }
cmd="$(cat "$INPUT_FILE")"
[[ -n "${cmd//[[:space:]]/}" ]] || { printf "NARF failed=true reason=empty-command\n"; exit 2; }
case "$cmd" in
  cd\ ~/Desktop/pinky-brain*|cd\ "$HOME/Desktop/pinky-brain"*|cd\ /Users/*/Desktop/pinky-brain*) ;;
  *) printf "NARF failed=true reason=command-must-start-in-pinky-brain\n"; exit 2 ;;
esac
case "$cmd" in
  *"<command>"*) printf "Narf! failed=true reason=placeholder-command-rejected\n"; exit 2 ;;
esac

hash="$(printf "%s" "$cmd" | shasum -a 256 | awk "{print \$1}")"
log="$LOG_DIR/$(date "+%Y%m%d-%H%M%S")-$hash.log"

printf "PINKY picked command:\n%s\n\n" "$cmd"
printf "PINKY executing in Terminal...\n"

"$ROOT_DIR/bin/pinky-preflight"

set +e
bash -n -c "$cmd" > "$log.syntax" 2>&1
syntax_code="$?"
if [[ "$syntax_code" != "0" ]]; then
  printf "Narf! failed=true reason=syntax-check-failed\n"
  cat "$log.syntax"
  exit 2
fi
bash -lc "$cmd" 2>&1 | head -c 200000 > "$log"
exit_code="${PIPESTATUS[0]}"
set -e

tail -80 "$log"
printf "\nNarf! exit=%s hash=%s log=%s\n" "$exit_code" "$hash" "$log"
exit "$exit_code"
