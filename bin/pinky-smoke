#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LOG_DIR="$ROOT_DIR/logs"

section() {
  printf "\n== %s ==\n" "$1"
}

cd "$ROOT_DIR"

"$ROOT_DIR/bin/pinky-cockpit"

section "runtime"
"$ROOT_DIR/bin/pinky-status" | sed -n "/--- runtime ---/,/--- signal ---/p" | sed "/--- signal ---/d"

section "git"
if [[ -n "$(git status --short)" ]]; then
  printf "git=dirty\n"
  git status --short | sed -n "1,40p"
else
  printf "git=clean\n"
fi
git status --short --branch

section "syntax"
bash -n \
  bin/pinky-cockpit \
  bin/pinky-status \
  bin/pinky-self-test \
  bin/pinky-loop \
  bin/pinky-detect-signal \
  bin/pinky-command-extract \
  bin/pinky-command-dry-run \
  bin/pinky-command-run
printf "syntax=pass\n"

section "fixtures"
tests/run-detect-signal-fixtures
tests/run-command-extract-fixtures
printf "fixtures=pass\n"

section "recent logs"
printf "%s\n" "--- pinky-loop.log ---"
tail -n 8 "$LOG_DIR/pinky-loop.log" 2>/dev/null || printf "none\n"
printf "%s\n" "--- pinky-signal.log ---"
tail -n 8 "$LOG_DIR/pinky-signal.log" 2>/dev/null || printf "none\n"
printf "%s\n" "--- pinky-command-run.log ---"
tail -n 6 "$LOG_DIR/pinky-command-run.log" 2>/dev/null || printf "none\n"

section "result"
printf "pinky-smoke=pass\n"

printf "\n--- report ---\n"
"$ROOT_DIR/bin/pinky-cockpit"
