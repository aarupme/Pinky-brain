#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
LOG_DIR="$ROOT_DIR/logs"
LOG_FILE="$LOG_DIR/pinky-sound.log"
SOUND_FILE="/System/Library/Sounds/Glass.aiff"

mkdir -p "$LOG_DIR"

timestamp() {
  date "+%Y-%m-%d %H:%M:%S"
}

if [[ ! -f "$SOUND_FILE" ]]; then
  printf "%s brain_ding=failed reason=missing-sound-file file=%s\n" "$(timestamp)" "$SOUND_FILE" >> "$LOG_FILE"
  echo "brain_ding=failed reason=missing-sound-file file=$SOUND_FILE" >&2
  exit 1
fi

if afplay "$SOUND_FILE"; then
  printf "%s brain_ding=played file=%s\n" "$(timestamp)" "$SOUND_FILE" >> "$LOG_FILE"
  echo "brain_ding=played file=$SOUND_FILE"
else
  exit_code="$?"
  printf "%s brain_ding=failed exit_code=%s file=%s\n" "$(timestamp)" "$exit_code" "$SOUND_FILE" >> "$LOG_FILE"
  echo "brain_ding=failed exit_code=$exit_code file=$SOUND_FILE" >&2
  exit "$exit_code"
fi
