#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
COMMAND="${1:-status}"
case "$COMMAND" in
  start) exec "$ROOT_DIR/bin/pinky-workhorse-start" ;;
  stop) exec "$ROOT_DIR/bin/pinky-workhorse-stop" ;;
  status) exec "$ROOT_DIR/bin/pinky-workhorse-status" ;;
  *) echo "usage: pinky-workhorse {start|stop|status}" >&2; exit 64 ;;
esac
