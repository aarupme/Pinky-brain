#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
fixture="${1:?fixture required}"
expected="${2:?expected command required}"
reader="$ROOT_DIR/.run/test-pinky-read-visible-command"
out="$ROOT_DIR/.run/test-command-extract-output"
code_editor_file="$ROOT_DIR/.run/pinky-code-editor-command.txt"
code_editor_saved="$ROOT_DIR/.run/test-pinky-code-editor-command.saved"
mkdir -p "$ROOT_DIR/.run"
cleanup() {
  rm -f "$ROOT_DIR/.run/pinky-command.last-hash" "$ROOT_DIR/.run/pinky-command.candidate" "$ROOT_DIR/.run/pinky-command.candidate.classification" "$ROOT_DIR/.run/pinky-command.candidate.reason" "$reader" "$out"
  if [[ -f "$code_editor_saved" ]]; then
    mv "$code_editor_saved" "$code_editor_file"
  fi
}
trap cleanup EXIT
rm -f "$ROOT_DIR/.run/pinky-command.last-hash" "$ROOT_DIR/.run/pinky-command.candidate" "$ROOT_DIR/.run/pinky-command.candidate.classification" "$ROOT_DIR/.run/pinky-command.candidate.reason" "$out"
if [[ -f "$code_editor_file" ]]; then
  mv "$code_editor_file" "$code_editor_saved"
fi
printf "#!/usr/bin/env bash\ncat \"%s\"\n" "$ROOT_DIR/tests/fixtures/$fixture" > "$reader"
chmod +x "$reader"
PINKY_READ_VISIBLE="$reader" "$ROOT_DIR/bin/pinky-command-extract" > "$out" || true
state="$(awk -F= '/^pinky_command=/{print $2; exit}' "$out")"
if [[ "$state" == "present" ]]; then
  candidate="$(awk -F= '/^candidate_file=/{print substr($0, index($0,"=")+1); exit}' "$out")"
  actual="$(cat "$candidate")"
else
  actual="none"
fi
if [[ "$actual" != "$expected" ]]; then
  echo "FAIL fixture=$fixture"
  echo "expected=$expected"
  echo "actual=$actual"
  cat "$out"
  exit 1
fi
echo "PASS fixture=$fixture runnable=$actual"
