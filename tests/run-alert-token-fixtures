#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT_DIR"

STATE_DIR="$(mktemp -d)"
STATE_FILE="$STATE_DIR/pinky-beacon.state"
ALERT_FILE="$STATE_DIR/pinky-beacon.alert"
cleanup() {
  rm -rf "$STATE_DIR"
}
trap cleanup EXIT

mkdir -p "$STATE_DIR"
rm -f "$ALERT_FILE"

PINKY_STATE_DIR="$STATE_DIR" ./bin/pinky-set-state stopped >/tmp/pinky-alert-token-stopped.out
if [[ -f "$ALERT_FILE" ]]; then
  echo "FAIL alert token file should not exist after stopped reset"
  exit 1
fi

PINKY_STATE_DIR="$STATE_DIR" ./bin/pinky-set-state brain fixture-token-1 >/tmp/pinky-alert-token-brain-1.out
state="$(cat "$STATE_FILE")"
alert="$(cat "$ALERT_FILE")"
if [[ "$state" != "brain" || "$alert" != "fixture-token-1" ]]; then
  echo "FAIL expected brain fixture-token-1 got state=$state alert=$alert"
  exit 1
fi

PINKY_STATE_DIR="$STATE_DIR" ./bin/pinky-set-state brain fixture-token-1 >/tmp/pinky-alert-token-repeat.out
repeat_alert="$(cat "$ALERT_FILE")"
if [[ "$repeat_alert" != "fixture-token-1" ]]; then
  echo "FAIL repeated token changed unexpectedly: $repeat_alert"
  exit 1
fi

PINKY_STATE_DIR="$STATE_DIR" ./bin/pinky-set-state brain fixture-token-2 >/tmp/pinky-alert-token-brain-2.out
new_alert="$(cat "$ALERT_FILE")"
if [[ "$new_alert" != "fixture-token-2" ]]; then
  echo "FAIL new token was not written: $new_alert"
  exit 1
fi

PINKY_STATE_DIR="$STATE_DIR" ./bin/pinky-set-state stopped >/tmp/pinky-alert-token-final-stop.out
echo "PASS alert-token-fixtures"
