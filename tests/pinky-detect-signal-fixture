#!/usr/bin/env bash
set -euo pipefail
ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"
fixture="${1:?fixture required}"
expected_signal="${2:?expected signal required}"
expected_hash="${3:-any}"
reader="$ROOT_DIR/.run/test-pinky-read-visible"
mkdir -p "$ROOT_DIR/.run"
cat > "$reader" <<SCRIPT
#!/usr/bin/env bash
cat "$ROOT_DIR/tests/fixtures/$fixture"
SCRIPT
chmod +x "$reader"
PATH="$ROOT_DIR/.run:$PATH" PINKY_READ_VISIBLE="$reader" "$ROOT_DIR/bin/pinky-detect-signal" > "$ROOT_DIR/.run/test-detect-output"
actual_signal="$(awk -F= '/^signal=/{print $2; exit}' "$ROOT_DIR/.run/test-detect-output")"
actual_hash="$(awk -F= '/^signal_hash=/{print $2; exit}' "$ROOT_DIR/.run/test-detect-output")"
if [[ "$actual_signal" != "$expected_signal" ]]; then
  echo "FAIL fixture=$fixture expected_signal=$expected_signal actual_signal=$actual_signal"
  cat "$ROOT_DIR/.run/test-detect-output"
  exit 1
fi
if [[ "$expected_hash" != "any" && "$actual_hash" != "$expected_hash" ]]; then
  echo "FAIL fixture=$fixture expected_hash=$expected_hash actual_hash=$actual_hash"
  cat "$ROOT_DIR/.run/test-detect-output"
  exit 1
fi
echo "PASS fixture=$fixture signal=$actual_signal hash=$actual_hash"
